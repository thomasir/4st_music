#!/usr/bin/env bash
# Heroku Python buildpack runs this after pip install.
# Downloads static ffmpeg+ffprobe so pytgcalls can find ffprobe.

BUILD_DIR=${1:-/app}

VENDOR="$BUILD_DIR/vendor/ffmpeg/bin"
EXTRACT="$BUILD_DIR/vendor/ffmpeg_tmp"

echo "-----> Installing FFmpeg (static build)"

mkdir -p "$VENDOR" "$EXTRACT"

echo "       Downloading..."
curl -fsSL "https://github.com/yt-dlp/FFmpeg-Builds/releases/download/latest/ffmpeg-master-latest-linux64-gpl.tar.xz" \
  -o "$EXTRACT/ffmpeg.tar.xz"

echo "       Extracting..."
tar -xJf "$EXTRACT/ffmpeg.tar.xz" -C "$EXTRACT" 2>/dev/null

# Find and copy the binaries
find "$EXTRACT" -name 'ffmpeg' -type f -exec cp {} "$VENDOR/ffmpeg" \; 2>/dev/null
find "$EXTRACT" -name 'ffprobe' -type f -exec cp {} "$VENDOR/ffprobe" \; 2>/dev/null

chmod +x "$VENDOR/ffmpeg" "$VENDOR/ffprobe" 2>/dev/null

# Cleanup
rm -rf "$EXTRACT"

if [ -x "$VENDOR/ffmpeg" ]; then
  VER=$("$VENDOR/ffmpeg" -version 2>&1 | head -1)
  echo "       $VER"
  echo "-----> FFmpeg installed successfully"
else
  echo "       WARNING: ffmpeg binary not found after extraction"
fi
