#!/usr/bin/env bash
# Heroku Python buildpack runs this after pip install completes.
# Downloads a static ffmpeg+ffprobe binary so pytgcalls can find ffprobe.

set -e

BUILD_DIR=$1   # /tmp/build_XXX during slug compile
CACHE_DIR=$2   # persistent cache across builds

VENDOR="$BUILD_DIR/vendor/ffmpeg/bin"
CACHE_BIN="$CACHE_DIR/ffmpeg_bin"

echo "-----> Installing FFmpeg (static build)"

if [ -d "$CACHE_BIN" ] && [ -x "$CACHE_BIN/ffmpeg" ]; then
  echo "       Using cached FFmpeg"
  mkdir -p "$VENDOR"
  cp "$CACHE_BIN/ffmpeg" "$VENDOR/ffmpeg"
  cp "$CACHE_BIN/ffprobe" "$VENDOR/ffprobe"
else
  echo "       Downloading FFmpeg static build..."
  mkdir -p "$VENDOR" "$CACHE_BIN"
  curl -sL "https://github.com/yt-dlp/FFmpeg-Builds/releases/download/latest/ffmpeg-master-latest-linux64-gpl.tar.xz" \
    | tar -xJ -C /tmp --wildcards '*/bin/ffmpeg' '*/bin/ffprobe' 2>/dev/null
  find /tmp -name 'ffmpeg' -newer /tmp -exec cp {} "$VENDOR/ffmpeg" \; 2>/dev/null || true
  find /tmp -name 'ffprobe' -newer /tmp -exec cp {} "$VENDOR/ffprobe" \; 2>/dev/null || true
  cp "$VENDOR/ffmpeg" "$CACHE_BIN/ffmpeg" 2>/dev/null || true
  cp "$VENDOR/ffprobe" "$CACHE_BIN/ffprobe" 2>/dev/null || true
fi

chmod +x "$VENDOR/ffmpeg" "$VENDOR/ffprobe" 2>/dev/null || true

VER=$("$VENDOR/ffmpeg" -version 2>&1 | head -1 || echo "check failed")
echo "       $VER"
echo "-----> FFmpeg installed at $VENDOR"
