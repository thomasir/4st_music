#!/usr/bin/env bash
# Heroku Python buildpack runs this after pip install.
# Downloads static ffmpeg+ffprobe so pytgcalls can find ffprobe.
#
# FIX: yt-dlp FFmpeg Builds "latest" tag is a rolling release — the .tar.xz
# filename changes with every nightly build, so curl was silently downloading
# a redirect/error page instead of the actual archive, leaving ffprobe missing.
# Now uses johnvansickle.com static builds — stable, versioned, reliable URL.

set -e

BUILD_DIR=${1:-/app}

VENDOR="$BUILD_DIR/vendor/ffmpeg/bin"
EXTRACT="$BUILD_DIR/vendor/ffmpeg_tmp"

mkdir -p "$VENDOR" "$EXTRACT"

echo "-----> Installing FFmpeg static build (johnvansickle)"

# johnvansickle static builds — amd64, GPL, self-contained, no shared libs
FFMPEG_URL="https://johnvansickle.com/ffmpeg/releases/ffmpeg-release-amd64-static.tar.xz"

echo "       Downloading..."
if ! curl -fsSL --retry 3 --retry-delay 5 "$FFMPEG_URL" -o "$EXTRACT/ffmpeg.tar.xz"; then
  echo "       Primary URL failed, trying GitHub mirror..."
  curl -fsSL --retry 3 --retry-delay 5 \
    "https://github.com/yt-dlp/FFmpeg-Builds/releases/download/latest/ffmpeg-n7.1-latest-linux64-gpl-7.1.tar.xz" \
    -o "$EXTRACT/ffmpeg.tar.xz" || true
fi

echo "       Extracting..."
tar -xf "$EXTRACT/ffmpeg.tar.xz" -C "$EXTRACT" 2>/dev/null || \
  tar -xJf "$EXTRACT/ffmpeg.tar.xz" -C "$EXTRACT" 2>/dev/null || true

# Find and copy the binaries wherever tar put them
find "$EXTRACT" -name 'ffmpeg'  -type f ! -name '*.xz' -exec cp {} "$VENDOR/ffmpeg"  \; 2>/dev/null || true
find "$EXTRACT" -name 'ffprobe' -type f ! -name '*.xz' -exec cp {} "$VENDOR/ffprobe" \; 2>/dev/null || true

chmod +x "$VENDOR/ffmpeg" "$VENDOR/ffprobe" 2>/dev/null || true

# Cleanup
rm -rf "$EXTRACT"

if [ -x "$VENDOR/ffmpeg" ] && [ -x "$VENDOR/ffprobe" ]; then
  VER=$("$VENDOR/ffmpeg" -version 2>&1 | head -1)
  echo "       $VER"
  echo "-----> FFmpeg + ffprobe installed at $VENDOR ✅"
else
  echo "       ⚠️  WARNING: ffmpeg/ffprobe binary not found — pytgcalls will fail"
  echo "          Check Heroku build logs. Add heroku-buildpack-apt and Aptfile"
  echo "          as a fallback: https://elements.heroku.com/buildpacks/heroku/heroku-buildpack-apt"
fi
